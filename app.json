{
  "expo": {
    "name": "Quazaar",
    "slug": "quazaar",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.codershubinc.quazaar"
    },
    "android": {
      "package": "com.codershubinc.quazaar",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "statusBar": {
        "hidden": true
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "135ff897-1ce7-45d0-a34b-98eb26d2c112"
      }
    },
    "plugins": [
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "NowPlaying",
              "label": "Now Playing",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "description": "Shows the currently playing track",
              "previewImage": "./assets/icon.png",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "react-native-health-connect",
        {
          "rationaleActivityName": "HealthConnectRationaleActivity"
        }
      ],
      "./plugins/withSpotifyQueries"
    ]
  }
}